<Application x:Class="LanTransfer.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:LanTransfer"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Converters -->
            <local:DirectionToIconConverter x:Key="DirectionToIcon"/>
            <local:DirectionToColorConverter x:Key="DirectionToColor"/>
            <local:FileSizeConverter x:Key="SizeConverter"/>
            <local:CountToVisibilityConverter x:Key="CountToVisibility"/>
            <local:DeviceToIconConverter x:Key="DeviceToIcon"/>
            <local:DeviceToColorConverter x:Key="DeviceToColor"/>
            <local:RunningToColorConverter x:Key="RunningToColor"/>
            <local:BoolToVisibilityConverter x:Key="BoolToVis"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
