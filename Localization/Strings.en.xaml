<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">

    <!-- XAML UI -->
    <sys:String x:Key="AppTitle">LAN File Transfer</sys:String>
    <sys:String x:Key="ConnectionInfo">Connection Info</sys:String>
    <sys:String x:Key="Address">Address:</sys:String>
    <sys:String x:Key="ClickToCopy">Click to copy</sys:String>
    <sys:String x:Key="ConnectionCodeLabel">Code:</sys:String>
    <sys:String x:Key="StatusLabel">Status:</sys:String>
    <sys:String x:Key="DragFilesHere">Drag files here</sys:String>
    <sys:String x:Key="OrClickToSelect">Or click to select files</sys:String>
    <sys:String x:Key="TabSent">Sent</sys:String>
    <sys:String x:Key="CancelSharing">Cancel sharing</sys:String>
    <sys:String x:Key="ClearAll">Clear All</sys:String>
    <sys:String x:Key="TabReceived">Received</sys:String>
    <sys:String x:Key="TabRecords">Records</sys:String>
    <sys:String x:Key="TabDevices">Devices</sys:String>
    <sys:String x:Key="TabLog">Log</sys:String>
    <sys:String x:Key="BottomTip">Devices on the same LAN can scan QR code or enter address to transfer files</sys:String>
    <sys:String x:Key="OpenFolder">Open received folder</sys:String>
    <sys:String x:Key="OpenInExplorer">Open in explorer</sys:String>
    <sys:String x:Key="VersionText">Version: HR.V1.2.0</sys:String>
    <sys:String x:Key="SwitchLang">中文</sys:String>
    <sys:String x:Key="Copy">Copy</sys:String>
    <sys:String x:Key="ScanToConnect">Scan to connect</sys:String>
    <sys:String x:Key="QuickShare">Share files to devices on the same LAN</sys:String>

    <!-- Status -->
    <sys:String x:Key="StatusNotStarted">Not started</sys:String>
    <sys:String x:Key="StatusRunning">Running</sys:String>
    <sys:String x:Key="StatusStartFailed">Start failed</sys:String>
    <sys:String x:Key="DeviceCountText">Connected devices: {0}</sys:String>

    <!-- Dialogs -->
    <sys:String x:Key="ErrorTitle">Error</sys:String>
    <sys:String x:Key="InitFailed">Initialization failed</sys:String>
    <sys:String x:Key="SelectType">Select Type</sys:String>
    <sys:String x:Key="SelectFolderOrFile">Select folder?&#x0a;&#x0a;Click [Yes] for folder&#x0a;Click [No] for files</sys:String>
    <sys:String x:Key="SelectFilesTitle">Select files to transfer</sys:String>

    <!-- Log messages -->
    <sys:String x:Key="FirewallFailed">Failed to add firewall rule. Please allow the port manually or run as administrator</sys:String>
    <sys:String x:Key="QrCodeFailed">QR code generation failed: {0}</sys:String>
    <sys:String x:Key="ServerError">Server error: {0}</sys:String>
    <sys:String x:Key="UrlCopied">Connection URL copied to clipboard</sys:String>
    <sys:String x:Key="CodeCopied">Connection code copied to clipboard</sys:String>
    <sys:String x:Key="FileNotFound">File not found: {0}</sys:String>
    <sys:String x:Key="FileShared">Shared: {0} ({1})</sys:String>
    <sys:String x:Key="CompressingFolder">Compressing folder: {0}...</sys:String>
    <sys:String x:Key="CompressFailed">Compression failed: {0}</sys:String>
    <sys:String x:Key="Unshared">Unshared: {0}</sys:String>
    <sys:String x:Key="AllCleared">All shared files cleared</sys:String>

    <!-- Server log -->
    <sys:String x:Key="ServerStarted">Server started: {0}</sys:String>
    <sys:String x:Key="DeviceUnknown">Unknown device</sys:String>
    <sys:String x:Key="DeviceAndroidPhone">Android Phone</sys:String>
    <sys:String x:Key="DeviceAndroidTablet">Android Tablet</sys:String>
    <sys:String x:Key="InvalidCode">Invalid connection code</sys:String>
    <sys:String x:Key="PageNotFound">Page not found</sys:String>
    <sys:String x:Key="RequestError">Request handling error: {0}</sys:String>
    <sys:String x:Key="FileExpired">File not found or expired</sys:String>
    <sys:String x:Key="SourceFileDeleted">Source file has been deleted</sys:String>
    <sys:String x:Key="RangeOutOfBounds">Request range out of bounds</sys:String>
    <sys:String x:Key="ResumeTransfer">Resuming: {0} ({1}) bytes={2}-{3}/{4}</sys:String>
    <sys:String x:Key="ResumeComplete">Resume complete: {0}</sys:String>
    <sys:String x:Key="DownloadStarted">Download started: {0} ({1}) &lt;- {2}</sys:String>
    <sys:String x:Key="DownloadComplete">Download complete: {0}, sent={1} bytes, match={2}</sys:String>
    <sys:String x:Key="UploadRequest">Upload request: {0}, CL={1}, CT={2}</sys:String>
    <sys:String x:Key="NoFileData">No file data</sys:String>
    <sys:String x:Key="UseMultipartFormat">Please use multipart/form-data format</sys:String>
    <sys:String x:Key="CannotParseBoundary">Cannot parse upload boundary</sys:String>
    <sys:String x:Key="NoFileDataParsed">No file data parsed</sys:String>
    <sys:String x:Key="ReceiveStarted">Receiving: {0} &lt;- {1}, CL={2}</sys:String>
    <sys:String x:Key="ReceiveComplete">Receive complete: {0} ({1})</sys:String>
    <sys:String x:Key="FileNotFoundInRequest">File not found</sys:String>
    <sys:String x:Key="SseConnected">SSE client connected: {0}</sys:String>
    <sys:String x:Key="DeviceDisconnected">Device disconnected: {0}</sys:String>
    <sys:String x:Key="ParsingUpload">Parsing upload, boundary={0}</sys:String>
    <sys:String x:Key="NoSectionParsed">No section parsed, returning error</sys:String>

    <!-- HTML pages -->
    <sys:String x:Key="HtmlTitle">LAN File Transfer</sys:String>
    <sys:String x:Key="HtmlEnterCode">Please enter 4-digit connection code</sys:String>
    <sys:String x:Key="HtmlConnect">Connect</sys:String>
    <sys:String x:Key="HtmlUploadToPeer">Upload files to peer</sys:String>
    <sys:String x:Key="HtmlClickOrDrag">Click or drag files here</sys:String>
    <sys:String x:Key="HtmlPreparing">Preparing...</sys:String>
    <sys:String x:Key="HtmlUploadSuccess">Upload successful</sys:String>
    <sys:String x:Key="HtmlUploadFailed">Upload failed</sys:String>
    <sys:String x:Key="HtmlNetworkError">Network error</sys:String>
    <sys:String x:Key="HtmlNoSharedFiles">No shared files</sys:String>
    <sys:String x:Key="HtmlDownload">Download</sys:String>
    <sys:String x:Key="HtmlErrorTitle">Error</sys:String>
    <sys:String x:Key="HtmlBackHome">Back to home</sys:String>
    <sys:String x:Key="HtmlDownloadableFiles">Downloadable Files</sys:String>

</ResourceDictionary>
