<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">

    <!-- XAML UI -->
    <sys:String x:Key="AppTitle">局域网文件传输</sys:String>
    <sys:String x:Key="ConnectionInfo">连接信息</sys:String>
    <sys:String x:Key="Address">地址:</sys:String>
    <sys:String x:Key="ClickToCopy">点击复制</sys:String>
    <sys:String x:Key="ConnectionCodeLabel">连接码:</sys:String>
    <sys:String x:Key="StatusLabel">状态:</sys:String>
    <sys:String x:Key="DragFilesHere">拖拽文件到此处</sys:String>
    <sys:String x:Key="OrClickToSelect">或点击选择文件</sys:String>
    <sys:String x:Key="TabSent">已发送</sys:String>
    <sys:String x:Key="CancelSharing">取消共享</sys:String>
    <sys:String x:Key="ClearAll">清空所有</sys:String>
    <sys:String x:Key="TabReceived">已接收</sys:String>
    <sys:String x:Key="TabRecords">传输记录</sys:String>
    <sys:String x:Key="TabDevices">设备</sys:String>
    <sys:String x:Key="TabLog">日志</sys:String>
    <sys:String x:Key="BottomTip">同一局域网内的设备可扫码或输入地址传输文件</sys:String>
    <sys:String x:Key="OpenFolder">打开接收文件夹</sys:String>
    <sys:String x:Key="OpenInExplorer">在资源管理器中打开</sys:String>
    <sys:String x:Key="VersionText">版本号：HR.V1.2.0</sys:String>
    <sys:String x:Key="SwitchLang">EN</sys:String>
    <sys:String x:Key="Copy">复制</sys:String>
    <sys:String x:Key="ScanToConnect">扫码连接</sys:String>
    <sys:String x:Key="QuickShare">快捷分享文件到同一局域网设备</sys:String>

    <!-- 状态 -->
    <sys:String x:Key="StatusNotStarted">未启动</sys:String>
    <sys:String x:Key="StatusRunning">运行中</sys:String>
    <sys:String x:Key="StatusStartFailed">启动失败</sys:String>
    <sys:String x:Key="DeviceCountText">已连接设备: {0}</sys:String>

    <!-- 对话框 -->
    <sys:String x:Key="ErrorTitle">错误</sys:String>
    <sys:String x:Key="InitFailed">初始化失败</sys:String>
    <sys:String x:Key="SelectType">选择类型</sys:String>
    <sys:String x:Key="SelectFolderOrFile">选择文件夹？&#x0a;&#x0a;点【是】选择文件夹&#x0a;点【否】选择文件</sys:String>
    <sys:String x:Key="SelectFilesTitle">选择要传输的文件</sys:String>

    <!-- 日志消息 -->
    <sys:String x:Key="FirewallFailed">防火墙规则添加失败，请手动放行端口或以管理员身份运行</sys:String>
    <sys:String x:Key="QrCodeFailed">二维码生成失败: {0}</sys:String>
    <sys:String x:Key="ServerError">服务器错误: {0}</sys:String>
    <sys:String x:Key="UrlCopied">连接地址已复制到剪贴板</sys:String>
    <sys:String x:Key="CodeCopied">连接码已复制到剪贴板</sys:String>
    <sys:String x:Key="FileNotFound">文件不存在: {0}</sys:String>
    <sys:String x:Key="FileShared">已共享: {0} ({1})</sys:String>
    <sys:String x:Key="CompressingFolder">正在压缩文件夹: {0}...</sys:String>
    <sys:String x:Key="CompressFailed">压缩失败: {0}</sys:String>
    <sys:String x:Key="Unshared">已取消共享: {0}</sys:String>
    <sys:String x:Key="AllCleared">已清空所有共享文件</sys:String>

    <!-- 服务器日志 -->
    <sys:String x:Key="ServerStarted">服务器已启动: {0}</sys:String>
    <sys:String x:Key="DeviceUnknown">未知设备</sys:String>
    <sys:String x:Key="DeviceAndroidPhone">Android 手机</sys:String>
    <sys:String x:Key="DeviceAndroidTablet">Android 平板</sys:String>
    <sys:String x:Key="InvalidCode">连接码错误</sys:String>
    <sys:String x:Key="PageNotFound">页面不存在</sys:String>
    <sys:String x:Key="RequestError">请求处理错误: {0}</sys:String>
    <sys:String x:Key="FileExpired">文件不存在或已过期</sys:String>
    <sys:String x:Key="SourceFileDeleted">源文件已被删除</sys:String>
    <sys:String x:Key="RangeOutOfBounds">请求范围越界</sys:String>
    <sys:String x:Key="ResumeTransfer">断点续传: {0} ({1}) bytes={2}-{3}/{4}</sys:String>
    <sys:String x:Key="ResumeComplete">续传完成: {0}</sys:String>
    <sys:String x:Key="DownloadStarted">开始下载: {0} ({1}) &lt;- {2}</sys:String>
    <sys:String x:Key="DownloadComplete">下载完成: {0}, 发送={1}字节, 匹配={2}</sys:String>
    <sys:String x:Key="UploadRequest">上传请求: {0}, CL={1}, CT={2}</sys:String>
    <sys:String x:Key="NoFileData">没有文件数据</sys:String>
    <sys:String x:Key="UseMultipartFormat">请使用 multipart/form-data 格式</sys:String>
    <sys:String x:Key="CannotParseBoundary">无法解析上传边界</sys:String>
    <sys:String x:Key="NoFileDataParsed">未解析到文件数据</sys:String>
    <sys:String x:Key="ReceiveStarted">开始接收: {0} &lt;- {1}, CL={2}</sys:String>
    <sys:String x:Key="ReceiveComplete">接收完成: {0} ({1})</sys:String>
    <sys:String x:Key="FileNotFoundInRequest">未找到文件</sys:String>
    <sys:String x:Key="SseConnected">SSE 客户端已连接: {0}</sys:String>
    <sys:String x:Key="DeviceDisconnected">设备已断开: {0}</sys:String>
    <sys:String x:Key="ParsingUpload">解析上传数据, boundary={0}</sys:String>
    <sys:String x:Key="NoSectionParsed">未解析到 section，返回错误</sys:String>

    <!-- HTML 页面 -->
    <sys:String x:Key="HtmlTitle">局域网文件传输</sys:String>
    <sys:String x:Key="HtmlEnterCode">请输入 4 位连接码</sys:String>
    <sys:String x:Key="HtmlConnect">连接</sys:String>
    <sys:String x:Key="HtmlUploadToPeer">上传文件到对方电脑</sys:String>
    <sys:String x:Key="HtmlClickOrDrag">点击选择或拖拽文件到此处</sys:String>
    <sys:String x:Key="HtmlPreparing">准备中...</sys:String>
    <sys:String x:Key="HtmlUploadSuccess">上传成功</sys:String>
    <sys:String x:Key="HtmlUploadFailed">上传失败</sys:String>
    <sys:String x:Key="HtmlNetworkError">网络错误</sys:String>
    <sys:String x:Key="HtmlNoSharedFiles">暂无共享文件</sys:String>
    <sys:String x:Key="HtmlDownload">下载</sys:String>
    <sys:String x:Key="HtmlErrorTitle">错误</sys:String>
    <sys:String x:Key="HtmlBackHome">返回首页</sys:String>
    <sys:String x:Key="HtmlDownloadableFiles">可下载的文件</sys:String>

</ResourceDictionary>
