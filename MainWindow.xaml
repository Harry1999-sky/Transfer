<Window x:Class="LanTransfer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:LanTransfer.ViewModels"
        Title="{DynamicResource AppTitle}" Height="800" Width="680"
        MinHeight="650" MinWidth="520"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBaseBrush}"
        Closing="Window_Closing">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <!-- Segmented control item style (shared) -->
        <Style x:Key="SegHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid Margin="{StaticResource PageMargin}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- Top bar -->
                <RowDefinition Height="Auto"/>   <!-- Connection card -->
                <RowDefinition Height="*"/>      <!-- Tab content -->
                <RowDefinition Height="Auto"/>   <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- ═══════════════════════════════════════════ -->
            <!--  TOP BAR                                    -->
            <!-- ═══════════════════════════════════════════ -->
            <Grid Grid.Row="0" Margin="0,0,0,16">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                               Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{DynamicResource AppTitle}" FontSize="17" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="{DynamicResource QuickShare}" FontSize="12"
                                   Foreground="{StaticResource TextTertiaryBrush}" Margin="0,1,0,0"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Margin="0,0,6,0"
                             Fill="{Binding IsRunning, Converter={StaticResource RunningToColor}}"/>
                    <TextBlock Text="{Binding StatusText}" FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <Button Content="{DynamicResource SwitchLang}" Style="{StaticResource OutlineButton}"
                            Click="LanguageToggle_Click" Padding="12,5"/>
                </StackPanel>
            </Grid>

            <!-- ═══════════════════════════════════════════ -->
            <!--  CONNECTION CARD                            -->
            <!-- ═══════════════════════════════════════════ -->
            <Border Grid.Row="1" Style="{StaticResource CardBorder}" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- QR Code -->
                    <Border Grid.Column="0" Style="{StaticResource QrContainer}">
                        <Image Source="{Binding QrCodeImage}" Stretch="Uniform" Margin="2"/>
                    </Border>

                    <!-- Right: Connection Info -->
                    <StackPanel Grid.Column="2" VerticalAlignment="Center">

                        <!-- Connection Code (hero) -->
                        <TextBlock Text="{DynamicResource ConnectionCodeLabel}" FontSize="12"
                                   Foreground="{StaticResource TextTertiaryBrush}" Margin="0,0,0,6"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <TextBlock Text="{Binding ConnectionCode}" FontSize="36" FontWeight="Bold"
                                       Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center"
                                       FontFamily="Segoe UI" Cursor="Hand"
                                       MouseLeftButtonDown="CodeText_MouseLeftButtonDown" ToolTip="{DynamicResource ClickToCopy}"/>
                            <Button Style="{StaticResource IconButton}" Margin="10,0,0,0"
                                    Command="{Binding CopyCodeCommand}" ToolTip="{DynamicResource Copy}" Content="&#xE8C8;"
                                    FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource TextTertiaryBrush}"/>
                        </StackPanel>

                        <!-- Address -->
                        <TextBlock Text="{DynamicResource Address}" FontSize="11"
                                   Foreground="{StaticResource TextTertiaryBrush}" Margin="0,0,0,3"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="{Binding ConnectionUrl}" FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"
                                       Cursor="Hand" MouseLeftButtonDown="UrlText_MouseLeftButtonDown" ToolTip="{DynamicResource ClickToCopy}"/>
                            <Button Style="{StaticResource IconButton}" Margin="6,0,0,0"
                                    Command="{Binding CopyUrlCommand}" ToolTip="{DynamicResource Copy}" Content="&#xE8C8;"
                                    FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource TextTertiaryBrush}" FontSize="12"/>
                        </StackPanel>

                        <!-- Scan tip -->
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                       Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="{DynamicResource ScanToConnect}" FontSize="12"
                                       Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding DeviceCountText}" FontSize="12"
                                       Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center" Margin="12,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══════════════════════════════════════════ -->
            <!--  SEGMENTED CONTROL + CONTENT                -->
            <!-- ═══════════════════════════════════════════ -->
            <Border Grid.Row="2" Style="{StaticResource CardBorder}" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Segmented Control Header -->
                    <Border Grid.Row="0" Background="{StaticResource BgCardAltBrush}"
                            CornerRadius="{StaticResource SmallRadius}" Padding="3" Margin="0,0,0,12">
                        <UniformGrid Columns="5">
                            <RadioButton x:Name="Tab0" Content="{DynamicResource TabSent}"
                                         Style="{StaticResource SegmentedRadio}" IsChecked="True"/>
                            <RadioButton x:Name="Tab1" Content="{DynamicResource TabReceived}"
                                         Style="{StaticResource SegmentedRadio}"/>
                            <RadioButton x:Name="Tab2" Content="{DynamicResource TabRecords}"
                                         Style="{StaticResource SegmentedRadio}"/>
                            <RadioButton x:Name="Tab3" Content="{DynamicResource TabDevices}"
                                         Style="{StaticResource SegmentedRadio}"/>
                            <RadioButton x:Name="Tab4" Content="{DynamicResource TabLog}"
                                         Style="{StaticResource SegmentedRadio}"/>
                        </UniformGrid>
                    </Border>

                    <!-- Content Panels (Visibility toggled by Tab RadioButton) -->
                    <Grid Grid.Row="1">

                        <!-- TAB 0: Sent Files -->
                        <Grid x:Name="PanelSent"
                              Visibility="{Binding IsChecked, ElementName=Tab0, Converter={StaticResource BoolToVis}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Drop Zone -->
                            <Border Grid.Row="0" x:Name="DropZone" Style="{StaticResource DropZoneBorder}"
                                    Margin="0,0,0,12" MouseLeftButtonDown="DropZone_MouseLeftButtonDown">
                                <StackPanel HorizontalAlignment="Center">
                                    <Border Width="48" Height="48" CornerRadius="24"
                                            Background="{StaticResource DropZoneBgBrush}" Margin="0,0,0,8">
                                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="22"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="{DynamicResource DragFilesHere}" FontSize="14" FontWeight="SemiBold"
                                               Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{DynamicResource OrClickToSelect}" FontSize="12"
                                               Foreground="{StaticResource TextTertiaryBrush}" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Shared Files List -->
                            <ListView Grid.Row="1" ItemsSource="{Binding SentFiles}"
                                      Style="{StaticResource ModernListView}">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="32" Height="32" CornerRadius="6"
                                                    Background="{StaticResource DropZoneBgBrush}" Margin="0,0,10,0">
                                                <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                           Foreground="{StaticResource AccentBrush}"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding FileName}" FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding FileSize, Converter={StaticResource SizeConverter}}" FontSize="11"
                                                           Foreground="{StaticResource TextTertiaryBrush}" Margin="0,1,0,0"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2" Text="Shared" FontSize="11"
                                                       Foreground="{StaticResource SuccessBrush}" VerticalAlignment="Center"
                                                       Margin="8,0,8,0"/>
                                            <Button Grid.Column="3" Content="&#xE711;" FontFamily="Segoe MDL2 Assets"
                                                    Style="{StaticResource IconButton}" FontSize="12"
                                                    Foreground="{StaticResource TextTertiaryBrush}"
                                                    ToolTip="{DynamicResource CancelSharing}"
                                                    MouseLeftButtonDown="UnshareFile_Click"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>

                            <!-- Clear All Button -->
                            <Button Grid.Row="2" Content="{DynamicResource ClearAll}" Style="{StaticResource DangerButton}"
                                    Command="{Binding ClearAllSharedCommand}"
                                    Visibility="{Binding SentFiles.Count, Converter={StaticResource CountToVisibility}}"
                                    HorizontalAlignment="Right" Margin="0,8,0,0"/>
                        </Grid>

                        <!-- TAB 1: Received Files -->
                        <Grid x:Name="PanelReceived"
                              Visibility="{Binding IsChecked, ElementName=Tab1, Converter={StaticResource BoolToVis}}">
                            <ListView ItemsSource="{Binding ReceivedFiles}" Style="{StaticResource ModernListView}">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="32" Height="32" CornerRadius="6"
                                                    Background="#E8F5E9" Margin="0,0,10,0">
                                                <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                           Foreground="{StaticResource SuccessBrush}"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding FileName}" FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding FileSize, Converter={StaticResource SizeConverter}}" FontSize="11"
                                                           Foreground="{StaticResource TextTertiaryBrush}" Margin="0,1,0,0"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2" Text="{Binding FileSize, Converter={StaticResource SizeConverter}}"
                                                       FontSize="12" Foreground="{StaticResource TextTertiaryBrush}"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>

                        <!-- TAB 2: Transfer Records -->
                        <ListView x:Name="PanelRecords" ItemsSource="{Binding TransferRecords}"
                                  Style="{StaticResource ModernListView}"
                                  Visibility="{Binding IsChecked, ElementName=Tab2, Converter={StaticResource BoolToVis}}">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="28" Height="28" CornerRadius="6" Margin="0,0,10,0"
                                                Background="{Binding Direction, Converter={StaticResource DirectionToColor}}"
                                                Opacity="0.9">
                                            <TextBlock Text="{Binding Direction, Converter={StaticResource DirectionToIcon}}"
                                                       FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="White"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding FileName}" FontSize="13"
                                                       Foreground="{StaticResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding FileSize, Converter={StaticResource SizeConverter}}" FontSize="11"
                                                       Foreground="{StaticResource TextTertiaryBrush}" Margin="0,1,0,0"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Text="{Binding RemoteIp}" FontSize="11"
                                                   Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Center"
                                                   Margin="8,0"/>
                                        <TextBlock Grid.Column="3" Text="{Binding Time, StringFormat=HH:mm:ss}" FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <!-- TAB 3: Devices -->
                        <Grid x:Name="PanelDevices"
                              Visibility="{Binding IsChecked, ElementName=Tab3, Converter={StaticResource BoolToVis}}">
                            <ListView ItemsSource="{Binding ConnectedDevices}" Style="{StaticResource ModernListView}">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="10" Margin="0,0,12,0"
                                                    Background="{Binding Name, Converter={StaticResource DeviceToColor}}">
                                                <TextBlock Text="{Binding Name, Converter={StaticResource DeviceToIcon}}"
                                                           FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="White"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                    <Ellipse Width="6" Height="6" Fill="{StaticResource SuccessBrush}"
                                                             VerticalAlignment="Center" Margin="0,0,5,0"/>
                                                    <TextBlock Text="Online" FontSize="11"
                                                               Foreground="{StaticResource SuccessBrush}" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2" Text="{Binding Ip}" FontSize="12"
                                                       Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Center"
                                                       FontFamily="Consolas"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>

                        <!-- TAB 4: Log -->
                        <Border x:Name="PanelLog" CornerRadius="{StaticResource SmallRadius}"
                                Background="#1E1E1E" Padding="14,10"
                                Visibility="{Binding IsChecked, ElementName=Tab4, Converter={StaticResource BoolToVis}}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <TextBlock Text="{Binding LogText}" Foreground="#D4D4D4" FontSize="12"
                                           FontFamily="Cascadia Code, Consolas, Courier New"
                                           TextWrapping="Wrap" LineHeight="20"/>
                            </ScrollViewer>
                        </Border>

                    </Grid>
                </Grid>
            </Border>

            <!-- ═══════════════════════════════════════════ -->
            <!--  FOOTER                                     -->
            <!-- ═══════════════════════════════════════════ -->
            <Grid Grid.Row="3" Margin="0,12,0,0">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{DynamicResource BottomTip}" FontSize="12"
                               Foreground="{StaticResource TextTertiaryBrush}"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0" Cursor="Hand"
                                MouseLeftButtonDown="OpenFolder_Click" ToolTip="{DynamicResource OpenInExplorer}">
                        <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="{DynamicResource OpenFolder}" FontSize="12"
                                   Foreground="{StaticResource AccentBrush}"/>
                    </StackPanel>
                </StackPanel>
                <TextBlock Text="{DynamicResource VersionText}" FontSize="11"
                           Foreground="{StaticResource TextTertiaryBrush}"
                           HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
