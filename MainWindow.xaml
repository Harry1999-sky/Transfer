<Window x:Class="LanTransfer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:LanTransfer.ViewModels"
        Title="局域网文件传输" Height="620" Width="520"
        MinHeight="500" MinWidth="420"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5"
        Closing="Window_Closing">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 连接信息卡片 -->
        <Border Grid.Row="0" Background="White" CornerRadius="12" Padding="16" Margin="0,0,0,12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="8" Opacity="0.1" ShadowDepth="2"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="连接信息" FontSize="14" Foreground="#999" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="地址:" Foreground="#666" Width="50" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding ConnectionUrl}" FontSize="15" Foreground="#333" FontWeight="SemiBold" VerticalAlignment="Center" Cursor="Hand" MouseLeftButtonDown="UrlText_MouseLeftButtonDown" ToolTip="点击复制"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="连接码:" Foreground="#666" Width="50" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding ConnectionCode}" FontSize="20" Foreground="#667eea" FontWeight="Bold" VerticalAlignment="Center" Cursor="Hand" MouseLeftButtonDown="CodeText_MouseLeftButtonDown" ToolTip="点击复制"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="状态:" Foreground="#666" Width="50" VerticalAlignment="Center"/>
                        <Ellipse Width="10" Height="10" Fill="#4CAF50" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding StatusText}" Foreground="#4CAF50" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <!-- 二维码 + 设备数 -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <Border Width="100" Height="100" CornerRadius="8" BorderBrush="#eee" BorderThickness="1" Background="White">
                        <Image Source="{Binding QrCodeImage}" Stretch="Uniform" Margin="4"/>
                    </Border>
                    <TextBlock Text="{Binding DeviceCountText}" Foreground="#667eea" FontSize="11" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 拖拽区域 -->
        <Border Grid.Row="1" x:Name="DropZone"
                Background="#F8F9FF" CornerRadius="12" Padding="24"
                BorderBrush="#667eea" BorderThickness="2"
                Margin="0,0,0,12" Cursor="Hand"
                MouseLeftButtonDown="DropZone_MouseLeftButtonDown">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="+" FontSize="36" Foreground="#667eea" HorizontalAlignment="Center"/>
                <TextBlock Text="拖拽文件到此处" Foreground="#667eea" FontSize="14" HorizontalAlignment="Center"/>
                <TextBlock Text="或点击选择文件" Foreground="#999" FontSize="12" HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- 传输记录 + 日志 -->
        <Border Grid.Row="2" Background="White" CornerRadius="12" Padding="12" Margin="0,0,0,12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="8" Opacity="0.1" ShadowDepth="2"/>
            </Border.Effect>
            <TabControl Background="Transparent" BorderThickness="0">
                <TabItem Header="已发送" FontSize="13">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <ListView ItemsSource="{Binding SentFiles}" BorderThickness="0" Background="Transparent">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding FileName}" Foreground="#333" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="1" Text="{Binding FileSize, Converter={StaticResource SizeConverter}}" Foreground="#999" Margin="8,0" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="×" Foreground="#e74c3c" FontSize="16" FontWeight="Bold" Cursor="Hand" Margin="8,0,0,0" VerticalAlignment="Center" ToolTip="取消共享"
                                                   MouseLeftButtonDown="UnshareFile_Click"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        <Button Grid.Row="1" Content="清空所有" Margin="0,8,0,0" HorizontalAlignment="Right"
                                Command="{Binding ClearAllSharedCommand}" Visibility="{Binding SentFiles.Count, Converter={StaticResource CountToVisibility}}"
                                Background="Transparent" Foreground="#e74c3c" BorderBrush="#e74c3c" Padding="12,4" Cursor="Hand"/>
                    </Grid>
                </TabItem>
                <TabItem Header="已接收" FontSize="13">
                    <Grid>
                        <ListView ItemsSource="{Binding ReceivedFiles}" BorderThickness="0" Background="Transparent">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding FileName}" Foreground="#333" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="1" Text="{Binding FileSize, Converter={StaticResource SizeConverter}}" Foreground="#999" Margin="8,0" VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </TabItem>
                <TabItem Header="传输记录" FontSize="13">
                    <ListView ItemsSource="{Binding TransferRecords}" BorderThickness="0" Background="Transparent">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                        <TextBlock Text="{Binding Direction, Converter={StaticResource DirectionToIcon}}" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding FileName}" Foreground="#333" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding FileSize, Converter={StaticResource SizeConverter}}" Foreground="#999" Margin="8,0" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Time, StringFormat=HH:mm:ss}" Foreground="#999" VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </TabItem>
                <TabItem Header="设备" FontSize="13">
                    <ListView ItemsSource="{Binding ConnectedDevices}" BorderThickness="0" Background="Transparent">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Ellipse Grid.Column="0" Width="8" Height="8" Fill="#4CAF50" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Name}" Foreground="#333" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Ip}" Foreground="#999" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </TabItem>
                <TabItem Header="日志" FontSize="13">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <TextBlock Text="{Binding LogText}" Foreground="#666" FontSize="12" FontFamily="Consolas" TextWrapping="Wrap" Padding="4"/>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Border>

        <!-- 底部提示 -->
        <Grid Grid.Row="3">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="同一局域网内的设备可扫码或输入地址传输文件" Foreground="#bbb" FontSize="12"/>
                <TextBlock Text="打开接收文件夹" Foreground="#667eea" FontSize="12" Cursor="Hand" Margin="0,4,0,0" MouseLeftButtonDown="OpenFolder_Click" ToolTip="在资源管理器中打开"/>
            </StackPanel>
            <TextBlock Text="版本号：HR.V1.0" Foreground="#ccc" FontSize="10" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
        </Grid>
    </Grid>
</Window>
